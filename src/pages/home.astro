---
import Layout from '../layouts/Layout.astro';



---
<Layout title="Landing">
  <div
    id="hero-mask"
    class="masked flex items-center justify-center gap-10 h-full bg-linear-to-br from-gray-900 to-gray-950"
  >
    <img src="me.png" alt="me" class="h-80" />
    <h1 class=" max-w-lg text-8xl font-bold bg-linear-to-r from-secondary via-tertiary to-primary to-80% bg-clip-text text-transparent align-middle">
      Welcome to my portfolio
    </h1>
  </div>
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const heroMask = document.querySelector('#hero-mask');

  if (heroMask) {
    gsap.to(
      heroMask,
      {
        webkitMaskSize: '1%',
        maskSize: '1%',
        ease: 'none',
        scrollTrigger: {
          trigger: heroMask,
          start: 'top top',
          end: '+=4000',
          scrub: true,
          pin: true
        }
      }
    );
  }
</script>