---
import Layout from '../layouts/Layout.astro';

---
<Layout title="Landing">
  <div
    id="hero-mask"
    class="masked h-full w-full"
  >
    <div id="content" class="h-full flex items-center justify-center gap-10 bg-linear-to-br from-gray-900 to-gray-950">
      <img src="me.png" alt="me" class="h-8/12 drop-shadow-secondary/20 drop-shadow-xl " />
        <h1 class=" max-w-lg text-8xl font-bold bg-linear-to-br from-secondary via-tertiary to-primary to-80% bg-clip-text text-transparent align-middle " >
          Welcome to my portfolio 
        </h1>
    </div>
  </div>
    <div id="three-overlay" aria-hidden="true"></div>
  <!-- div used for trigger the onComplete event of the animation -->
  <div class="h-px"></div>
  <!-- link used for redirect with transitions -->
  <a href="/menu" id="menu-link" />
</Layout>

<style>
  #content{
    transform: scale(1.5);
  }

    #three-overlay {
      position: fixed;
      inset: 0;
      z-index: 50;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.4s ease;
      background: #020617;
      pointer-events: none;
    }

    #three-overlay canvas {
      width: 100%;
      height: 100%;
      display: block;
    }
</style>

<script>
  import { initializeHomeLandingScene } from '../lib/homeLandingScene';

  initializeHomeLandingScene();
</script>
